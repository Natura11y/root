{
  "name": "@natura11y/icons",
  "version": "2.2.0",
  "description": "Open source icon library for the Natura11y Design Ecosystem.",
  "private": false,
  "style": "dist/natura11y-icons.min.css",
  "files": [
    ".fantasticonrc.js",
    "dist",
    "original-svg",
    "optimized-svg",
    "scripts",
    "src/data",
    "README.md",
    "svgo.config.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Natura11y/root.git",
    "directory": "packages/icons"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "design system",
    "icons",
    "icon font",
    "svg",
    "web accessibility"
  ],
  "author": "Avidano Digital",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Natura11y/root/issues"
  },
  "homepage": "https://gonatura11y.com/docs/icon/",
  "devDependencies": {
    "csso": "^5.0.5",
    "fantasticon": "^3.0.0",
    "svgo": "^3.0.2"
  },
  "scripts": {
    "optimize-icons": "svgo -f ./original-svg -o ./optimized-svg",
    "build-icons": "fantasticon ./optimized-svg -o ./dist",
    "minify-icons-css": "node scripts/minify-icons-css.mjs",
    "build:icons": "npm run optimize-icons && npm run build-icons && npm run minify-icons-css"
  }
}
