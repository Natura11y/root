{
  "name": "@natura11y/react",
  "version": "1.0.0-beta",
  "description": "React components for the Natura11y Design Ecosystem.",
  "type": "module",
  "private": false,
  "main": "./dist/natura11y-react.cjs",
  "module": "./dist/natura11y-react.js",
  "types": "./dist/components/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/natura11y-react.js",
      "require": "./dist/natura11y-react.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks.js",
      "require": "./dist/hooks.cjs"
    }
  },
  "files": [
    "CHANGELOG.md",
    "dist/*.js",
    "dist/*.cjs",
    "dist/**/*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Natura11y/root.git",
    "directory": "packages/react"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "design system",
    "react",
    "react components",
    "ui",
    "web accessibility"
  ],
  "author": "Avidano Digital",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Natura11y/root/issues"
  },
  "homepage": "https://gonatura11y.com/docs/react/",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --mode demo --outDir demo-dist",
    "preview": "vite preview --outDir demo-dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@natura11y/core": "^5.2.1",
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "web-vitals": "^4.2.4"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
