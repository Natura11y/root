{
  "name": "@natura11y/react",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "main": "./dist/natura11y-react.cjs",
  "module": "./dist/natura11y-react.js",
  "types": "./dist/components/natura11y/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/components/natura11y/index.d.ts",
      "import": "./dist/natura11y-react.js",
      "require": "./dist/natura11y-react.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks.js",
      "require": "./dist/hooks.cjs"
    }
  },
  "files": [
    "CHANGELOG.md",
    "dist/*.js",
    "dist/*.cjs",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@natura11y/core": "^5.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@natura11y/core": "^5.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.28.1",
    "typescript": "^5.6.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "web-vitals": "^4.2.4"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
