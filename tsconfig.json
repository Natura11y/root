{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@lib/*": ["./src/*"]
    }
  },
  "include": ["src/components/natura11y", "src/hooks", "src/stories", "src/types", ".storybook"],
  "exclude": ["node_modules", "dist"]
}
