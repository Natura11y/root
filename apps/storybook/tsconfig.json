{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@lib/*": ["../../packages/react/src/*"]
    }
  },
  "include": [
    ".storybook/**/*",
    "src/**/*",
    "../../packages/react/src/types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "storybook-static"]
}
