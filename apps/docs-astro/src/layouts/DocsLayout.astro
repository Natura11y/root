---
import '@natura11y-icons/natura11y-icons.css';
import '../styles/global.scss';

interface Props {
  frontmatter: {
    title?: string;
  };
}

const { frontmatter } = Astro.props;
const title = frontmatter.title ?? 'Natura11y Astro Docs Spike';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <main class="docs-astro-shell theme-canvas">
      <slot />
    </main>
  </body>
</html>
