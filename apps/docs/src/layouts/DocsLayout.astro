---
import { Picture } from 'astro:assets';
import type { ImageMetadata, MarkdownHeading } from 'astro';
import PrismLoader from '../components/docs/CodeBlock/PrismLoader.astro';
import OnThisPage from '../components/docs/OnThisPage.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  docs?: Array<{
    data: {
      title: string;
      slug: string;
      category?: string;
    };
  }>;
  currentSlug?: string;
  headings?: MarkdownHeading[];
  frontmatter?: {
    title?: string;
    description?: string;
    bannerImage?: ImageMetadata;
    bannerAlt?: string;
    bannerCreditName?: string;
    bannerCreditUrl?: string;
  };
}

const { docs = [], currentSlug = '', headings = [], frontmatter = {} } = Astro.props;
const title = frontmatter.title ?? 'Natura11y Astro Docs Spike';
const sortedDocs = [...docs].sort((a, b) => a.data.title.localeCompare(b.data.title));
const bannerImage = frontmatter.bannerImage;
const bannerAlt = frontmatter.bannerAlt ?? '';
---

<BaseLayout title={title} description={frontmatter.description}>

  <div class="docs-layout">
    
    <aside class="docs-layout__nav">

      {sortedDocs.length > 0 && (
        <nav aria-label="Documentation">
          <ul class="nav">
            {sortedDocs.map((doc) => (
              <li>
                <a
                  class:list={[
                    'text-decoration-none',
                    doc.data.slug === currentSlug && 'font-weight-bold',
                  ]}
                  href={`/docs/${doc.data.slug}/`}
                  aria-current={doc.data.slug === currentSlug ? 'page' : undefined}
                >
                  {doc.data.title}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}
    </aside>

    <header class="docs-layout__banner backdrop backdrop--fixed theme-dark aspect-ratio-banner">
      {bannerImage && (
        <div class="backdrop__media">
          <Picture
            class="opacity-40"
            src={bannerImage}
            formats={['avif', 'webp']}
            alt={bannerAlt}
          />

          {frontmatter.bannerCreditName && (
            <div class="backdrop__media__credit margin-1">
              <p>
                <em>
                  Photo:{' '}
                  {frontmatter.bannerCreditUrl ? (
                    <a class="text-decoration-underline" href={frontmatter.bannerCreditUrl} target="_blank" rel="noreferrer">
                      {frontmatter.bannerCreditName}
                    </a>
                  ) : (
                    frontmatter.bannerCreditName
                  )}
                </em>
              </p>
            </div>
          )}
        </div>
      )}

      <div class="backdrop__cover">
        <div class="container narrow">
          <h1 class="banner-headline text-shadow">{title}</h1>
        </div>
      </div>
    </header>

    <OnThisPage headings={headings} />

    <div class="docs-layout__body">
      <slot />
    </div>
  </div>

  <PrismLoader />
</BaseLayout>
