---
import BaseLayout from './BaseLayout.astro';
import { Picture } from 'astro:assets';

import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';

import OnThisPage from '../components/ui/OnThisPage.astro';
import SearchDocs from '../components/ui/SearchDocs/SearchDocs.astro';

interface Props {
  docs?: CollectionEntry<'docs'>[];
  currentSlug?: string;
  frontmatter?: {
    title?: string;
    description?: string;
    bannerImage?: ImageMetadata;
    bannerAlt?: string;
    bannerCreditName?: string;
    bannerCreditUrl?: string;
  };
  tocSections?: Array<{
    id: string;
    text: string;
    depth: number;
  }>;
}

const { docs = [], currentSlug = '', frontmatter = {}, tocSections = [] } = Astro.props;
const siteTitle = 'Natura11y Design Ecosystem';
const pageTitle = frontmatter.title ?? siteTitle;
const documentTitle = pageTitle === siteTitle ? siteTitle : `${pageTitle} • ${siteTitle}`;
const visibleDocs = docs.filter((doc) => doc.data.draft !== true);
const introductionDocs = visibleDocs
  .filter((doc) => doc.data.category === 'introduction')
  .sort((a, b) => (a.data.navOrder ?? 999) - (b.data.navOrder ?? 999) || a.data.title.localeCompare(b.data.title));
const alphabeticalDocs = visibleDocs
  .filter((doc) => doc.data.category === 'a-z')
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
const navGroups = [introductionDocs, alphabeticalDocs].filter((group) => group.length > 0);
const bannerImage = frontmatter.bannerImage;
const bannerAlt = frontmatter.bannerAlt ?? '';
---

<BaseLayout title={documentTitle} description={frontmatter.description}>

  <div class="docs-layout">
    
    <aside class="docs-layout__nav">
      <div class="doc-left-rail">
        <div class="container narrow">
          <div class="grid gap-2">
            <SearchDocs />

            <button
              class="button button--outline button--disperse font-size-md display-none--xl"
              aria-expanded="false"
              aria-controls="docs-sidebar"
              data-toggle="collapse"
              type="button"
            >
              <span class="text">Documentation</span>
              <span class="icon icon-arrow-down button__icon" aria-hidden="true"></span>
            </button>
          </div>

          <div class="position-relative collapse shown--xl" id="docs-sidebar">
            
            <a class="focusable-only" href="#primary-content">
              Skip Navigation
            </a>

            <div class="padding-y-3">
              
              {navGroups.length > 0 && (
                <nav class="grid grid--divider gap-4" aria-label="Documentation">
                  {navGroups.map((group) => (
                    <ul class="nav font-size-md">
                      {group.map((doc) => (
                        <li>
                          <a
                            class:list={[
                              'text-decoration-none',
                              doc.data.slug === currentSlug && 'font-weight-bold',
                            ]}
                            href={`/docs/${doc.data.slug}/`}
                            aria-current={doc.data.slug === currentSlug ? 'page' : undefined}
                          >
                            {doc.data.title}
                          </a>
                        </li>
                      ))}
                    </ul>
                  ))}
                </nav>
              )}

            </div>
          
          </div>
        
        </div>
      
      </div>
    
    </aside>

    <header class="docs-layout__banner backdrop backdrop--fixed theme-dark aspect-ratio-banner">
      
      {bannerImage && (
        <div class="backdrop__media">
          
          <Picture
            class="opacity-40"
            src={bannerImage}
            formats={['avif', 'webp']}
            alt={bannerAlt}
            layout="full-width"
            priority
          />

          {frontmatter.bannerCreditName && (
            <div class="backdrop__media__credit margin-1">
              <p>
                <em>
                  Photo:{' '}
                  {frontmatter.bannerCreditUrl ? (
                    <a class="text-decoration-underline" href={frontmatter.bannerCreditUrl} target="_blank" rel="noreferrer">
                      {frontmatter.bannerCreditName}
                    </a>
                  ) : (
                    frontmatter.bannerCreditName
                  )}
                </em>
              </p>
            </div>
          )}
        </div>
      )}

      <div class="backdrop__cover">

        <div>
          <div class="container narrow">
            <h1 class="banner-headline text-shadow">{pageTitle}</h1>
          </div>
        </div>
      
      </div>
    
    </header>

    <OnThisPage sections={tocSections} />

    <div class="docs-layout__body">
      <slot />
    </div>

  </div>

</BaseLayout>
