---
import '@natura11y-icons/natura11y-icons.css';
import GlobalFooter from '../components/ui/GlobalFooter/GlobalFooter.astro';
import GlobalHeader from '../components/ui/GlobalHeader/GlobalHeader.astro';
import '../styles/global.scss';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>

<html class="theme-canvas" lang="en">

  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <script is:inline>
      (() => {
        const storageKey = 'preferred-theme';
        const themeClasses = ['theme-canvas', 'theme-dark', 'theme-canvas--prefers'];
        const themeClassMap = {
          light: 'theme-canvas',
          dark: 'theme-dark',
          os: 'theme-canvas--prefers',
        };

        const getStoredTheme = () => {
          try {
            const storedTheme = window.localStorage.getItem(storageKey);
            return Object.hasOwn(themeClassMap, storedTheme) ? storedTheme : 'light';
          } catch {
            return 'light';
          }
        };

        const applyTheme = (theme) => {
          const root = document.documentElement;
          const themeClass = themeClassMap[theme] || themeClassMap.light;

          root.classList.remove(...themeClasses);
          root.classList.add(themeClass);
          root.dataset.theme = theme;
        };

        applyTheme(getStoredTheme());
      })();
    </script>
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  
  <body id="top">
    <div class="skip-links">
      <a href="#primary-content">Skip to content</a>
      <a href="#global-footer">Skip to footer</a>
    </div>
    <GlobalHeader />
    <main id="primary-content">
      <slot />
    </main>
    <GlobalFooter />
    <script>
      import '../scripts/natura11y';
    </script>
  </body>

</html>
