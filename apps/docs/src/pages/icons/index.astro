---
import { natura11yIcons } from '@natura11y/icons/src/data/icons.mjs';
import BaseLayout from '../../layouts/BaseLayout.astro';
import IconModal from '../../components/ui/IconModal/IconModal.astro';

const title = 'Icons • Natura11y Design Ecosystem';
const description =
  "Discover Natura11y's beautiful, clean open source icons - free to use with no sign-ups required. Use them as is or customize with GitHub source files for a tailored web design experience.";

const icons = [...natura11yIcons].sort((a, b) => a.icon.localeCompare(b.icon));
const getIconModalId = (className: string) => `icon-${className}-modal`;
const iconGridStyle = [
  '--icon-size: 2.25em',
  '--button-icon-only-size: 2.5em',
  '--button-icon-over-text-width: 100%',
  '--button-icon-over-text-font-size: 0.75em',
].join('; ');
---

<BaseLayout title={title} description={description}>

  <header class="container narrow margin-y-5 text-align-center">
    <h1>Natura11y Has Its Own Icon Library</h1>

    <p>
      Natura11y icons are free for both personal and commercial use. No email address or sign-up required.
    </p>

    <a class="button font-size-md text-color-link" href="/docs/icon/">
      <span class="text">Using the Icons</span>
      <span class="icon icon-arrow-right" aria-hidden="true"></span>
    </a>
  </header>

  <section class="container wide margin-y-5" aria-label="Natura11y icon library">
    <form class="form-entry form-entry--search" role="search" aria-label="Search icons" data-icon-search-form>
      <label class="form-entry__field">
        <span class="form-entry__field__label screen-reader-only">Search Icons</span>
        <span class="form-entry__field__input">
          <span class="icon icon-search opacity-50" aria-hidden="true"></span>
          <input
            type="search"
            id="icon-search"
            name="icon-search"
            placeholder="Search Icons"
            aria-controls="natura11yIconGrid"
            autocomplete="off"
            data-icon-search
          />
          <button
            class="button button--icon-only"
            type="button"
            data-search-clear
            aria-label="Clear search"
            aria-controls="icon-search"
          >
            <span class="icon icon-clear" aria-hidden="true"></span>
          </button>
        </span>
      </label>
    </form>

    <div class="text-align-center margin-y-4">
      <p class="screen-reader-only" aria-live="polite" data-icon-search-status>
        {icons.length} icons available.
      </p>

      <ul
        class="grid grid--column-3 grid--column-4--md grid--column-8--lg gap-3"
        id="natura11yIconGrid"
        style={iconGridStyle}
      >
        {icons.map((icon) => (
          <li
            data-icon-item
            data-icon-keywords={[icon.icon, icon.className, ...icon.tags].join(' ').toLowerCase()}
          >
            <button
              class="button button--icon-over-text"
              type="button"
              data-modal="open"
              data-icon-modal-trigger
              data-icon-class-name={icon.className}
              aria-controls={getIconModalId(icon.className)}
              aria-label={`View ${icon.icon} icon details`}
            >
              <span class="button__icon width-100">
                <span class={`icon icon-${icon.className}`} aria-hidden="true"></span>
              </span>
              <span class="button__text font-weight-normal opacity-80">
                {icon.className}
              </span>
            </button>
          </li>
        ))}
      </ul>

      <div class="container narrow text-align-center" data-icon-no-results hidden>
        <pre class="h2 code-font" aria-hidden="true">
          <code data-icon-no-results-art></code>
        </pre>
        <p class="h6">
          No results found for '<span data-icon-search-term></span>'
        </p>
      </div>
    </div>
  </section>

  <IconModal icons={icons} />

</BaseLayout>

<script>
  const initializeIconSearch = () => {
    const searchForm = document.querySelector<HTMLFormElement>('[data-icon-search-form]');
    const searchInput = document.querySelector<HTMLInputElement>('[data-icon-search]');
    const iconItems = Array.from(document.querySelectorAll<HTMLElement>('[data-icon-item]'));
    const noResults = document.querySelector<HTMLElement>('[data-icon-no-results]');
    const noResultsArt = document.querySelector<HTMLElement>('[data-icon-no-results-art]');
    const searchTerm = document.querySelector<HTMLElement>('[data-icon-search-term]');
    const searchStatus = document.querySelector<HTMLElement>('[data-icon-search-status]');
    const noResultsArtwork = [
      `.__.
{O,o}
/)__)
" "`,
      `/\\_/\\
( o.o )
>^_^<`,
      `><(((º>
'''`,
      ` (\\(\\
  ( -.-)
o_(")(")`,
      `/\\_/\\
(°ᴥ°)
/  \\`,
    ];
    let lastNoResultsQuery = '';

    if (!searchInput || iconItems.length === 0) {
      return;
    }

    const setNoResultsArtwork = (query: string) => {
      if (!noResultsArt || query === lastNoResultsQuery) {
        return;
      }

      const randomIndex = Math.floor(Math.random() * noResultsArtwork.length);
      noResultsArt.textContent = noResultsArtwork[randomIndex] ?? noResultsArtwork[0];
      lastNoResultsQuery = query;
    };

    const filterIcons = () => {
      const query = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      iconItems.forEach((item) => {
        const keywords = item.dataset.iconKeywords ?? '';
        const isMatch = query === '' || keywords.includes(query);

        item.hidden = !isMatch;

        if (isMatch) {
          visibleCount += 1;
        }
      });

      if (noResults) {
        noResults.hidden = visibleCount > 0;
      }

      if (visibleCount === 0) {
        setNoResultsArtwork(query);
      } else {
        lastNoResultsQuery = '';
      }

      if (searchTerm) {
        searchTerm.textContent = query;
      }

      if (searchStatus) {
        searchStatus.textContent = query
          ? `${visibleCount} icons found for ${query}.`
          : `${visibleCount} icons available.`;
      }
    };

    searchForm?.addEventListener('submit', (event) => {
      event.preventDefault();
    });
    searchInput.addEventListener('input', filterIcons);
    filterIcons();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeIconSearch, { once: true });
  } else {
    initializeIconSearch();
  }
</script>
