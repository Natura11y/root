---
import { Image } from 'astro:assets';

import BaseLayout from '../layouts/BaseLayout.astro';
import flockImage from '../assets/about/about-flock.jpg';
import grassrootsImage from '../assets/about/about-grassroots.jpg';
import lifecycleImage from '../assets/about/about-lifecycle.jpg';
import pronunciationImage from '../assets/about/pronounced.jpg';
import beeImage from '../assets/about/about-bee.jpg';

const title = 'About • Natura11y Design Ecosystem';
const description =
  'Natura11y is an independent open source design ecosystem for building accessible websites with shared CSS, JavaScript, React components, icons, Figma assets, documentation, and examples that help teams move from design to production with less rework.';
---

<BaseLayout title={title} description={description}>

  <section class="backdrop " style="--backdrop-fixed-height: min(760px, 90dvh); --gradient-direction-start: 35%;">
    <div class="backdrop__media">
      <Image
        class="opacity-70 gradient-mask-vignette"
        src={flockImage}
        alt=""
        widths={[640, 960, 1280, 1600, 2000]}
        sizes="100vw"
        priority
      />
    </div>

    <div class="backdrop__cover">

      <div class="container medium margin-y-6 text-shadow--lg">

        <h1 class="banner-headline text-align-center margin-bottom-4">
          Natura11y is for people who give a flock about accessibility
        </h1>

        <div class="container narrow font-size-lg">
        
        <p>
          Accessibility should be part of the first draft, not a cleanup project after everything else is finished.
        </p>

        <p>
          Natura11y gives teams a practical foundation for building accessible websites with shared CSS, JavaScript, React starter components, icons, Figma UI kits, documentation, and examples.
        </p>
        </div>

      </div>
    </div>
  </section>

  <section class="backdrop " style="--backdrop-fixed-height: min(760px, 90dvh); --gradient-direction-start: 35%;">
    <div class="backdrop__media">
      <Image
        class="opacity-70 gradient-mask-vignette"
        src={lifecycleImage}
        alt=""
        widths={[640, 960, 1280, 1600, 2000]}
        sizes="100vw"
      />
    </div>

    <div class="backdrop__cover">

      <div class="container medium margin-y-6 text-shadow--lg">

        <h2 class="banner-headline text-align-center margin-bottom-4">
          Natura11y is for every stage of the project lifecycle
        </h2>

        <div class="container narrow font-size-lg">

          <p>
            Designers get Figma kits and component patterns that can survive implementation. Developers get CSS, JavaScript, React starter components, and copyable examples that reduce repeated interface work. Website owners get a foundation that is easier to maintain, extend, and trust after launch.
          </p>

          <p>
            Components like Track, Lightbox, Main Menu, Dropdown, Mega Menu, Modal, Tabs, and Forms handle the details teams rebuild over and over: focus, keyboard behavior, ARIA state, responsive layout, reduced motion, validation, and clear user feedback.
          </p>
        </div>

      </div>
    </div>
  </section>

  <section class="backdrop " style="--backdrop-fixed-height: min(760px, 90dvh); --gradient-direction-start: 35%;">
    <div class="backdrop__media">
      <Image
        class="opacity-70 gradient-mask-vignette"
        src={grassrootsImage}
        alt=""
        widths={[640, 960, 1280, 1600, 2000]}
        sizes="100vw"
      />
    </div>

    <div class="backdrop__cover">

      <div class="container medium margin-y-6 text-shadow--lg">

        <h2 class="banner-headline text-align-center margin-bottom-4">
          Natura11y is a grassroots effort. It’s not corporate-owned.
        </h2>

        <div class="container narrow font-size-lg">

          <p>
            Natura11y is independent, open source, and shaped by the kind of work small teams actually do: building useful websites with limited time, real content, real users, and real accessibility responsibilities.
          </p>

          <p>
            It is not trying to lock teams into a product suite or a single way of working. The priorities are simpler: readable HTML, flexible adoption, useful examples, and accessible components that keep working after a site is handed off.
          </p>
        </div>

      </div>
    </div>
  </section>

  <section class="backdrop " style="--backdrop-fixed-height: min(760px, 90dvh); --gradient-direction-start: 35%;">
    <div class="backdrop__media">
      <Image
        class="opacity-70 gradient-mask-vignette"
        src={pronunciationImage}
        alt=""
        widths={[640, 960, 1280, 1600, 2000]}
        sizes="100vw"
      />
    </div>

    <div class="backdrop__cover">

      <div class="container medium margin-y-6 text-shadow--lg">

        <h2 class="banner-headline text-align-center margin-bottom-4">
          Natura11y is pronounced naturally (natch-er-uh-lee)
        </h2>

        <div class="container narrow font-size-lg">

          <p>
            The name carries the accessibility shorthand <code>a11y</code>, but you say it like the word naturally.
          </p>

          <p>
            That is the point of the project too. Accessible design should feel like the natural way to build, not a separate track reserved for audits, specialists, or the end of the project.
          </p>
        </div>

      </div>
    </div>
  </section>

  <section class="backdrop " style="--backdrop-fixed-height: min(760px, 90dvh); --gradient-direction-start: 35%;">
    <div class="backdrop__media">
      <Image
        class="opacity-70 gradient-mask-vignette"
        src={beeImage}
        alt=""
        widths={[640, 960, 1280, 1600, 2000]}
        sizes="100vw"
      />
    </div>

    <div class="backdrop__cover">

      <div class="container medium margin-y-6 text-shadow--lg">

        <h2 class="banner-headline text-align-center margin-bottom-4">
          Bee a part of Natura11y's growth
        </h2>

        <div class="container narrow font-size-lg">

          <p>
            Open source only gets better when people use it in real projects and speak up about what is missing, confusing, or worth improving.
          </p>

          <p>
            Try the components, test the examples, read the docs with fresh eyes, and share where Natura11y can be clearer or more useful. The project is created and maintained by <a class="link" href="https://avidanodigital.com/" target="_blank" rel="noreferrer">Avidano Digital</a>, a disability-led, multi-cultural design studio serving nonprofit and social impact organizations.
          </p>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
