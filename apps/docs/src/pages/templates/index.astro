---
import BaseLayout from '../../layouts/BaseLayout.astro';

import ResourceCard from '../../components/ui/ResourceCard/ResourceCard.astro';

import { templates } from '../../data/templates';

const title = 'Templates • Natura11y Inclusive Framework';
const description = 'Natura11y HTML templates give you the right page structure from the start: landmarks, heading order, skip links, and ARIA labels already in place. No visual style applied. Use one as your starting point.';
---

<BaseLayout title={title} description={description}>

  <section class="container narrow text-align-center margin-y-5">
    <h1>Templates</h1>
    <p>
      Templates give you a starting point for common page types. Landmarks, heading order, skip links, and ARIA labels already in place. No visual style applied.
    </p>
  </section>

  <section class="container wide margin-y-5 text-align-center">

    <div class="grid grid--column-3--lg gap-3">
      {templates.map((template) => (
        <ResourceCard
          title={template.title}
          description={template.description}
          image={template.image}
          imageLoading="eager"
          primaryUrl={template.previewUrl}
          primaryLabel="Preview Template"
          secondaryUrl={template.codeUrl}
        />
      ))}
    </div>

  </section>

</BaseLayout>
