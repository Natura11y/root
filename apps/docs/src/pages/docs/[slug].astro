---
import { getCollection, render } from 'astro:content';

import DocsLayout from '../../layouts/DocsLayout.astro';
import AccessibilitySpotlight from '../../components/ui/AccessibilitySpotlight/AccessibilitySpotlight.astro';
import FeatureCard from '../../components/ui/FeatureCard/FeatureCard.astro';
import FigureExample from '../../components/ui/FigureExample/FigureExample.astro';
import FigureImage from '../../components/ui/FigureImage/FigureImage.astro';
import LinkOpenNew from '../../components/ui/LinkOpenNew.astro';
import RelatedPages from '../../components/ui/RelatedPages/RelatedPages.astro';
import RelatedCustomProperties from '../../components/ui/tables/RelatedCustomProperties.astro';
import Section from '../../components/ui/Section.astro';
import TableLineDescBlock from '../../components/ui/tables/TableLineDescBlock.astro';
import TableLineDescRow from '../../components/ui/tables/TableLineDescRow.astro';
import TextBlock from '../../components/ui/TextBlock.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');

  return docs.map((doc) => ({
    params: { slug: doc.data.slug },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const docs = await getCollection('docs');
const { Content } = await render(doc);
type DocsEntry = (typeof docs)[number];
const relatedPages = (doc.data.relatedPages ?? [])
  .map((title) => docs.find((page) => page.data.title === title))
  .filter((page): page is DocsEntry => Boolean(page));

const toPlainText = (value: string) => value
  .replace(/<[^>]+>/g, ' ')
  .replace(/[`*_~]/g, '')
  .replace(/\s+/g, ' ')
  .trim();

const tocSections = [...doc.body.matchAll(/<Section\s+[^>]*id=["']([^"']+)["'][^>]*>([\s\S]*?)<\/Section>/g)]
  .map((section) => {
    const [, id, body] = section;
    const markdownHeading = body.match(/^(#{2,6})\s+(.+)$/m);
    const htmlHeading = body.match(/<h([2-6])[^>]*>([\s\S]*?)<\/h\1>/i);

    if (markdownHeading) {
      return {
        id,
        text: toPlainText(markdownHeading[2]),
        depth: markdownHeading[1].length,
      };
    }

    if (htmlHeading) {
      return {
        id,
        text: toPlainText(htmlHeading[2]),
        depth: Number(htmlHeading[1]),
      };
    }

    return {
      id,
      text: 'Untitled Section',
      depth: 2,
    };
  });
---

<DocsLayout
  docs={docs}
  currentSlug={doc.data.slug}
  frontmatter={doc.data}
  tocSections={tocSections}
>
  <Content
    components={{
      AccessibilitySpotlight,
      FeatureCard,
      FigureExample,
      FigureImage,
      LinkOpenNew,
      RelatedCustomProperties,
      Section,
      TableLineDescBlock,
      TableLineDescRow,
      TextBlock,
    }}
  />

  <RelatedPages pages={relatedPages} />
</DocsLayout>
