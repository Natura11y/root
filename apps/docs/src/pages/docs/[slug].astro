---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import AccessibilitySpotlight from '../../components/docs/AccessibilitySpotlight.astro';
import FigureExample from '../../components/docs/FigureExample.astro';
import LinkOpenNew from '../../components/docs/LinkOpenNew.astro';
import Section from '../../components/docs/Section.astro';
import ShikiFigureExample from '../../components/docs/ShikiFigureExample.astro';
import TableLineDescBlock from '../../components/docs/TableLineDescBlock.astro';
import TableLineDescRow from '../../components/docs/TableLineDescRow.astro';
import TextBlock from '../../components/docs/TextBlock.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');

  return docs.map((doc) => ({
    params: { slug: doc.data.slug },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const docs = await getCollection('docs');
const { Content, headings } = await render(doc);
---

<DocsLayout docs={docs} currentSlug={doc.data.slug} frontmatter={doc.data} headings={headings}>
  <Content
    components={{
      AccessibilitySpotlight,
      FigureExample,
      LinkOpenNew,
      Section,
      ShikiFigureExample,
      TableLineDescBlock,
      TableLineDescRow,
      TextBlock,
    }}
  />
</DocsLayout>
