---
import { Image } from 'astro:assets';

import BaseLayout from '../layouts/BaseLayout.astro';
import bannerIntroduction from '../assets/home/banner-introduction.jpg';
import exampleFeature from '../assets/example-thumbnails/peak-performance-page.jpg';
import templateFeature from '../assets/template-thumbnails/template-landing.jpg';
import accessibilityFeature from '../content/docs/banner/accessibility.jpg';
import backdropFeature from '../content/docs/banner/backdrop.jpg';
import colorFeature from '../content/docs/banner/color.jpg';
import customizationFeature from '../content/docs/banner/customization.jpg';
import figmaFeature from '../content/docs/banner/figma.jpg';
import formFeature from '../content/docs/banner/form.jpg';
import iconFeature from '../content/docs/banner/icon.jpg';
import mainMenuFeature from '../content/docs/banner/main-menu.jpg';
import reactFeature from '../content/docs/banner/react.jpg';

const title = 'Natura11y Design Ecosystem';
const description =
  'Natura11y is a user-friendly front end ecosystem. Natura11y provides bleeding-edge CSS, modern JavaScript, and its own icon library. Get started using CDNs, NPM, or Webpack. Start creating amazing web experiences with Natura11y.';

const ecosystemFeatures = [
  {
    headline: 'Accessibility',
    description:
      'Build websites everyone can use. Accessible patterns and interactions are included from the start.',
    image: accessibilityFeature,
    altText: 'A giraffe reaching for a leaf',
    href: '/docs/accessibility/',
  },
  {
    headline: 'Customization',
    description:
      'Make Natura11y yours, from website themes to comprehensive design systems.',
    image: customizationFeature,
    altText: 'Close up of a beautiful chameleon',
    href: '/docs/customization/',
  },
  {
    headline: 'Dynamic Color System',
    description:
      'Go beyond dark mode with color themes for pages or components, even at specific breakpoints.',
    image: colorFeature,
    altText: 'Yellow, blue, red, and green bird in close-up photograph',
    href: '/docs/color/',
  },
  {
    headline: 'Figma UI Kits',
    description:
      'Move from early exploration to a complete design system with two free Figma UI Kits.',
    image: figmaFeature,
    altText: 'A plate of figs on a tablecloth',
    href: '/docs/figma/',
  },
  {
    headline: 'Icons',
    description:
      'Access 100+ open-source icons, or build your own custom icon font, all without creating an account or paying a dime.',
    image: iconFeature,
    altText: 'A silhouette of a parrot on bare branches',
    href: '/icons/',
  },
  {
    headline: 'React',
    description:
      "Build with React using the same CSS foundation as Natura11y's HTML components.",
    image: reactFeature,
    altText: 'Two great black-backed gulls on a rocky beach',
    href: '/docs/react/',
  },
  {
    headline: 'Main Menu',
    description:
      'Build responsive headers with dedicated areas for your logo, navigation, search, and actions.',
    image: mainMenuFeature,
    altText: 'A lion with a full mane looking into the distance',
    href: '/docs/main-menu/',
  },
  {
    headline: 'Forms',
    description:
      'Create accessible forms with consistent styling for inputs, selects, validation, checkboxes, radio buttons, and more.',
    image: formFeature,
    altText: 'Four whales swimming in the ocean',
    href: '/docs/form/',
  },
  {
    headline: 'Backdrop',
    description:
      'Place semantic images or video behind content with responsive, proportional, fixed-height, and stacked layouts.',
    image: backdropFeature,
    altText: 'A mountain landscape beneath a cloudy sky',
    href: '/docs/backdrop/',
  },
];
---

<BaseLayout title={title} description={description}>

  <section class="backdrop theme-dark backdrop--stack--lg">

    <div class="backdrop__media">

      <Image
        class="opacity-40"
        src={bannerIntroduction}
        alt="A hummingbird pollinating a flower"
        widths={[640, 960, 1280, 1600, 2000]}
        sizes="100vw"
        priority
      />

      <div class="backdrop__media__credit margin-1">
        <p>
          <em>
            Photo:{' '}
            <a
              class="text-decoration-underline"
              href="https://unsplash.com/@zmachacek"
              target="_blank"
              rel="noreferrer"
              aria-label="Photo credit Zdenek Machacek (opens in a new tab)"
            >
              Zdenek Machacek
            </a>
          </em>
        </p>
      </div>
    
    </div>

    <div class="backdrop__cover">

      <div class="container wide margin-y-3">

        <h1 class="banner-headline text-align-center margin-x-auto text-shadow--lg width-80--xl margin-bottom-4">
          Natura11y helps you make websites beautiful <em>and</em> accessible
        </h1>

        <div class="container narrow">
          <div class="grid narrow grid--column-2--md gap-2">
            <a class="button theme-primary" href="/docs/get-started/">
              <span class="text">Get Started</span>
            </a>
            <a class="button theme-secondary" href="/about/">
              <span class="text">About</span>
            </a>
          </div>
        </div>

      </div>

    </div>
  
  </section>

  <section class="padding-y-5">

    <div class="container narrow margin-bottom-4 text-align-center">

      <h2>A Design ECOsystem</h2>

      <p>
        Natura11y is an open-source toolkit for designing, building, and maintaining inclusive user interfaces.
      </p>

      <img
        class="home-ecosystem-logos"
        src="/docs-assets/home/ecosystem-logos.svg"
        alt="Natura11y ecosystem powered by Webpack, HTML5, Sass, JavaScript, React, and Figma"
        loading="lazy"
      />
    </div>

    <div class="container wide--md">

      <div class="grid grid--column-3--lg gap-2 text-align-center">
        {ecosystemFeatures.map((feature) => (
          <a class="card subtle-fill-1 border-radius-2 text-decoration-none" href={feature.href}>
            <div class="card__media border-radius-2">
              <Image
                class="home-card-image"
                src={feature.image}
                alt={feature.altText}
                widths={[320, 480, 640, 768, 960]}
                sizes="(min-width: 992px) 30vw, 100vw"
              />
            </div>

            <div class="card__body">
              <h3 class="h4">{feature.headline}</h3>
              <p>{feature.description}</p>
            </div>
          </a>
        ))}
      </div>
      
    </div>
  
  </section>

  <hr />

  <section class="padding-y-5">

    <div class="container wide--md">

      <div class="grid grid--column-2--md gap-4">
        <a
          class="card card--horizontal border-radius-2 subtle-fill-1"
          href="/templates/"
        >
          <div class="card__media border-radius-2">
            <Image
              src={templateFeature}
              alt=""
              widths={[240, 320, 480]}
              sizes="(min-width: 768px) 16vw, 33vw"
            />
          </div>

          <div class="card__body container">
            <h2 class="h4">Templates</h2>
            <p>Start faster with accessible page structures and essential semantics already in place.</p>
          </div>
        </a>

        <a
          class="card card--horizontal border-radius-2 subtle-fill-1"
          href="/examples/"
        >
          <div class="card__media border-radius-2">
            <Image
              src={exampleFeature}
              alt=""
              widths={[240, 320, 480]}
              sizes="(min-width: 768px) 16vw, 33vw"
            />
          </div>

          <div class="card__body">
            <h2 class="h4">Examples</h2>
            <p>See what’s possible with Natura11y through styled pages with distinct visual directions.</p>
          </div>
        </a>
      </div>

    </div>

  </section>

</BaseLayout>
