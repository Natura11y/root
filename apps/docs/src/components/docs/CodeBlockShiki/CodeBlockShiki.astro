---
import { codeToHtml } from 'shiki';
import type { ShikiTransformer } from 'shiki';
import './code-block-shiki.scss';

interface Props {
  preID?: string | null;
  highlightedLines?: string | null;
  codeToolbar?: boolean;
  codeLanguage?: string;
  codeExample?: string | null;
  code?: string | null;
  downloadUrl?: string | null;
}

const {
  preID = null,
  highlightedLines = null,
  codeToolbar = true,
  codeLanguage = 'html',
  codeExample = null,
  code = null,
  downloadUrl = null,
} = Astro.props;

const codeText = codeExample ?? code;
const language = codeLanguage.toLowerCase();
const highlightedLinesValue = highlightedLines == null ? null : String(highlightedLines);
const languageLabels: Record<string, string> = {
  bash: 'Shell',
  css: 'CSS',
  html: 'HTML',
  javascript: 'JavaScript',
  js: 'JavaScript',
  json: 'JSON',
  jsx: 'JSX',
  markup: 'HTML',
  scss: 'SCSS',
  shell: 'Shell',
  ts: 'TypeScript',
  tsx: 'TSX',
  typescript: 'TypeScript',
};
const languageLabel = languageLabels[language] ?? language.toUpperCase();

const parseHighlightedLines = (value: string | null) => {
  const lines = new Set<number>();

  if (!value) {
    return lines;
  }

  value.split(',').forEach((part) => {
    const [startValue, endValue] = part.split('-').map((item) => Number.parseInt(item.trim(), 10));

    if (Number.isNaN(startValue)) {
      return;
    }

    const end = endValue === undefined || Number.isNaN(endValue) ? startValue : endValue;

    for (let line = startValue; line <= end; line += 1) {
      lines.add(line);
    }
  });

  return lines;
};

const parseLineAnchors = (value: string | null) => {
  const anchors = new Map<number, string>();

  if (!value || !preID) {
    return anchors;
  }

  value.split(',').forEach((part) => {
    const range = part.trim().replace(/\s+/gu, '');
    const [startValue] = range.split('-').map((item) => Number.parseInt(item, 10));

    if (!range || Number.isNaN(startValue)) {
      return;
    }

    anchors.set(startValue, `${preID}.${range}`);
  });

  return anchors;
};

const highlightedLineNumbers = parseHighlightedLines(highlightedLinesValue);
const lineAnchors = parseLineAnchors(highlightedLinesValue);
const shikiTransformers: ShikiTransformer[] = [
{
  name: 'natura11y-pre-attributes',
  pre(node) {
    const className = node.properties?.class;
    const classes = Array.isArray(className)
      ? className
      : typeof className === 'string'
        ? className.split(/\s+/u).filter(Boolean)
        : [];

    node.properties = {
      ...node.properties,
      ...(preID ? { id: preID } : {}),
      ...(highlightedLines ? { 'data-line': highlightedLines } : {}),
      ...(downloadUrl ? { 'data-src': downloadUrl, 'data-download-link': true } : {}),
      class: [
        ...classes,
        'astro-code',
        'shiki-code',
        codeToolbar === false ? 'hide-toolbar' : null,
      ].filter(Boolean),
    };

    return node;
  },
},
{
  name: 'natura11y-highlight-lines',
  postprocess(html: string) {
    let lineNumber = 0;

    return html.replace(/<span class="line"/gu, (match) => {
      lineNumber += 1;
      const lineAnchor = lineAnchors.get(lineNumber);
      const lineAnchorAttribute = lineAnchor ? ` id="${lineAnchor}"` : '';

      return highlightedLineNumbers.has(lineNumber)
        ? `<span class="line shiki-line-highlight"${lineAnchorAttribute} data-line-number="${lineNumber}"`
        : match.replace('<span class="line"', `<span class="line"${lineAnchorAttribute}`);
    });
  },
},
];

const highlightedCode = codeText
  ? await codeToHtml(codeText, {
      lang: language,
      themes: {
        light: 'github-light',
        dark: 'github-dark',
      },
      defaultColor: 'light',
      transformers: shikiTransformers,
    })
  : null;
---

<div class="example__code example__code--shiki">
  {highlightedCode ? (
    codeToolbar ? (
      <div class="code-toolbar">
        <Fragment set:html={highlightedCode} />

        <div class="toolbar">
          <div class="toolbar-item">
            <span>{languageLabel}</span>
          </div>

          <div class="toolbar-item">
            <button class="copy-to-clipboard-button" type="button" data-shiki-copy data-copy-state="copy">
              <span>Copy</span>
            </button>
          </div>
        </div>
      </div>
    ) : (
      <Fragment set:html={highlightedCode} />
    )
  ) : (
    <p>No code provided.</p>
  )}
</div>

<script>
  const setupKey = '__natura11yShikiCopy';

  if (!Reflect.get(window, setupKey)) {
    Reflect.set(window, setupKey, true);

    const labels = {
      copy: 'Copy',
      success: 'Copied!',
      error: 'Press Ctrl+C to copy',
    };

    const getCodeText = (toolbar) => {
      const lines = toolbar.querySelectorAll('code .line');

      if (lines.length) {
        return Array.from(lines)
          .map((line) => line.textContent ?? '')
          .join('\n');
      }

      return toolbar.querySelector('code')?.textContent ?? '';
    };

    const setButtonState = (button, state) => {
      const label = button.querySelector('span');
      button.dataset.copyState = state;

      if (label) {
        label.textContent = labels[state];
      }
    };

    const fallbackCopy = (text) => {
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.insetBlockStart = '0';
      textarea.style.insetInlineStart = '0';
      textarea.style.opacity = '0';

      document.body.appendChild(textarea);
      textarea.select();

      const copied = document.execCommand('copy');
      document.body.removeChild(textarea);

      return copied;
    };

    document.addEventListener('click', async (event) => {
      const target = event.target;

      if (!(target instanceof Element)) {
        return;
      }

      const button = target.closest('[data-shiki-copy]');

      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      const toolbar = button.closest('.code-toolbar');
      const codeText = toolbar ? getCodeText(toolbar) : '';

      if (!codeText) {
        setButtonState(button, 'error');
        window.setTimeout(() => setButtonState(button, 'copy'), 5000);
        return;
      }

      try {
        let copied = false;

        if (navigator.clipboard) {
          try {
            await navigator.clipboard.writeText(codeText);
            copied = true;
          } catch {
            copied = false;
          }
        }

        if (!copied && !fallbackCopy(codeText)) {
          throw new Error('Copy command failed.');
        }

        setButtonState(button, 'success');
      } catch {
        setButtonState(button, 'error');
      }

      window.setTimeout(() => setButtonState(button, 'copy'), 5000);
    });
  }
</script>
