---
import CodeBlock from './CodeBlock/CodeBlock.astro';

interface Props {
  figureNumber?: string | number;
  figureWidth?: string;
  visualExampleClass?: string | null;
  codeToolbar?: boolean;
  codeLanguage?: string;
  codeExample?: string | null;
  code?: string | null;
  highlightedLines?: string | null;
  hideFigCaption?: boolean;
  downloadUrl?: string | null;
}

const {
  figureNumber = null,
  figureWidth = 'medium--lg',
  visualExampleClass = null,
  codeToolbar = true,
  codeLanguage = 'html',
  codeExample = null,
  code = null,
  highlightedLines = null,
  hideFigCaption = false,
  downloadUrl = null,
} = Astro.props;

const hasVisualExample = Astro.slots.has('default');
const figureId = figureNumber ? `figcaption_${figureNumber}` : undefined;
---

<div
  class="container margin-y-5"
  aria-labelledby={figureId}
>
  <figure
    class:list={[
      'example',
      'example--code',
      figureWidth,
      'margin-x-auto',
      'border-radius-2',
      'box-shadow-2',
    ]}
    role="figure"
  >
    {hasVisualExample ? (
      <div class="example__visual overflow-hidden">
        <div class:list={['padding-y-5', visualExampleClass]}>
          <div class="container narrow">
            <slot />
          </div>
        </div>

        <CodeBlock
          preID={figureNumber ? `code_${figureNumber}` : null}
          highlightedLines={highlightedLines}
          codeToolbar={codeToolbar}
          codeLanguage={codeLanguage}
          codeExample={codeExample}
          code={code}
          downloadUrl={downloadUrl}
        />
      </div>
    ) : (
      <CodeBlock
        preID={figureNumber ? `code_${figureNumber}` : null}
        highlightedLines={highlightedLines}
        codeToolbar={codeToolbar}
        codeLanguage={codeLanguage}
        codeExample={codeExample}
        code={code}
        downloadUrl={downloadUrl}
      />
    )}

    {figureNumber !== null && !hideFigCaption && (
      <figcaption id={figureId} class="example__caption">
        Figure {figureNumber}
      </figcaption>
    )}
  </figure>
</div>
