---
import Brand from '../main-menu/Brand.astro';
import FlyoutDemoBehavior from './FlyoutDemoBehavior.astro';
import './flyout-demo.scss';

interface Props {
  id?: string;
}

const {
  id = 'flyout-panels-example',
} = Astro.props;
---

<div class="flyout-demo" data-flyout-demo>
  <div class="flyout-demo__page container width-100 padding-y-2 box-shadow-1">
    <div class="justify-content-between align-items-center display-flex">
      <a href="#1" title="Home" data-logo="brand">
        <Brand />
      </a>

      <button
        class="button button--icon-only font-size-md"
        data-flyout-demo-open
        aria-controls={id}
        aria-label="Open Menu"
        aria-expanded="true"
        type="button"
      >
        <span class="icon icon-menu" aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <div
    class="flyout-demo__overlay is-open"
    id={id}
    data-flyout-demo-overlay
    aria-hidden="false"
  >
    <div
      class="flyout-demo__content"
      role="dialog"
      aria-modal="true"
      aria-label="Main Menu"
    >
      <div class="flyout-demo__header">
        <button
          class="button button--icon-only font-size-md"
          data-flyout-demo-back
          aria-label="Back"
          type="button"
          hidden
        >
          <span class="icon icon-arrow-left" aria-hidden="true"></span>
        </button>

        <button
          class="button button--icon-only font-size-md"
          data-flyout-demo-close
          aria-label="Close Menu"
          type="button"
        >
          <span class="icon icon-close" aria-hidden="true"></span>
        </button>
      </div>

      <nav class="flyout-demo__body" aria-label="Main Menu Navigation">
        <div class="flyout-demo__panels">
          <div class="flyout-demo__panel is-active" data-flyout-demo-panel>
            <ul class="nav nav--divider">
              <li>
                <button data-flyout-demo-next aria-controls={`${id}-panel-wildlife`} type="button">
                  Wildlife
                  <span class="icon icon-arrow-right" aria-hidden="true"></span>
                </button>
              </li>
              <li>
                <button data-flyout-demo-next aria-controls={`${id}-panel-trails`} type="button">
                  Trails
                  <span class="icon icon-arrow-right" aria-hidden="true"></span>
                </button>
              </li>
              <li><a href="#1">Events</a></li>
              <li><a href="#1">About</a></li>
              <li><a href="#1">Contact</a></li>
            </ul>
          </div>

          <div class="flyout-demo__panel" id={`${id}-panel-wildlife`} data-flyout-demo-panel inert>
            <div class="flyout-demo__panel-title">
              <p>Wildlife</p>
            </div>
            <ul class="nav nav--divider">
              <li>
                <button data-flyout-demo-next aria-controls={`${id}-panel-birds`} type="button">
                  Birds
                  <span class="icon icon-arrow-right" aria-hidden="true"></span>
                </button>
              </li>
              <li>
                <button data-flyout-demo-next aria-controls={`${id}-panel-mammals`} type="button">
                  Mammals
                  <span class="icon icon-arrow-right" aria-hidden="true"></span>
                </button>
              </li>
              <li>
                <button data-flyout-demo-next aria-controls={`${id}-panel-reptiles`} type="button">
                  Reptiles
                  <span class="icon icon-arrow-right" aria-hidden="true"></span>
                </button>
              </li>
              <li><a href="#1">All Wildlife</a></li>
            </ul>
          </div>

          <div class="flyout-demo__panel" id={`${id}-panel-trails`} data-flyout-demo-panel inert>
            <div class="flyout-demo__panel-title">
              <p>Trails</p>
            </div>
            <ul class="nav nav--divider">
              <li><a href="#1">Easy</a></li>
              <li><a href="#1">Moderate</a></li>
              <li><a href="#1">Strenuous</a></li>
              <li><a href="#1">All Trails</a></li>
            </ul>
          </div>

          <div class="flyout-demo__panel" id={`${id}-panel-birds`} data-flyout-demo-panel inert>
            <div class="flyout-demo__panel-title">
              <p>Birds</p>
            </div>
            <ul class="nav nav--divider">
              <li><a href="#1">Waterfowl</a></li>
              <li><a href="#1">Raptors</a></li>
              <li><a href="#1">Shorebirds</a></li>
              <li><a href="#1">All Birds</a></li>
            </ul>
          </div>

          <div class="flyout-demo__panel" id={`${id}-panel-mammals`} data-flyout-demo-panel inert>
            <div class="flyout-demo__panel-title">
              <p>Mammals</p>
            </div>
            <ul class="nav nav--divider">
              <li><a href="#1">Bears</a></li>
              <li><a href="#1">Deer</a></li>
              <li><a href="#1">Foxes</a></li>
              <li><a href="#1">All Mammals</a></li>
            </ul>
          </div>

          <div class="flyout-demo__panel" id={`${id}-panel-reptiles`} data-flyout-demo-panel inert>
            <div class="flyout-demo__panel-title">
              <p>Reptiles</p>
            </div>
            <ul class="nav nav--divider">
              <li><a href="#1">Turtles</a></li>
              <li><a href="#1">Lizards</a></li>
              <li><a href="#1">Snakes</a></li>
              <li><a href="#1">All Reptiles</a></li>
            </ul>
          </div>
        </div>
      </nav>
    </div>
  </div>
</div>

<FlyoutDemoBehavior />
