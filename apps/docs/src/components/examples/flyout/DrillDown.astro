---
import Brand from '../main-menu/Brand.astro';

interface Props {
  id?: string;
}

const {
  id = 'flyout-panels-example',
} = Astro.props;
---

<div class="flyout-example">
  <div class="container width-100 padding-y-2 box-shadow-1">
    <div class="justify-content-between align-items-center display-flex">
      <a href="#1" title="Home" data-logo="brand">
        <Brand />
      </a>

      <button
        class="button button--icon-only font-size-md"
        data-open="flyout"
        aria-controls={id}
        aria-label="Open Menu"
        type="button"
      >
        <span class="icon icon-menu" aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <div
    class="flyout shown"
    id={id}
    aria-hidden="false"
    style="position: absolute; inset: 0;"
  >
    <div
      class="flyout__content"
      role="dialog"
      aria-modal="true"
      aria-label="Main Menu"
      style="height: 100%;"
    >
      <div class="flyout__header">
        <button
          class="button button--icon-only font-size-md"
          data-flyout-back
          aria-label="Back"
          type="button"
          hidden
        >
          <span class="icon icon-arrow-left" aria-hidden="true"></span>
        </button>

        <button
          class="button button--icon-only font-size-md"
          data-flyout-close
          aria-label="Close Menu"
          type="button"
        >
          <span class="icon icon-close" aria-hidden="true"></span>
        </button>
      </div>

      <nav class="flyout__body" aria-label="Main Menu Navigation">
        <div class="flyout__panels">
          <div class="flyout__panel">
            <ul class="nav nav--divider">
              <li>
                <button data-flyout-next aria-controls={`${id}-panel-wildlife`} type="button">
                  Wildlife
                  <span class="icon icon-arrow-right" aria-hidden="true"></span>
                </button>
              </li>
              <li>
                <button data-flyout-next aria-controls={`${id}-panel-trails`} type="button">
                  Trails
                  <span class="icon icon-arrow-right" aria-hidden="true"></span>
                </button>
              </li>
              <li><a href="#1">Events</a></li>
              <li><a href="#1">About</a></li>
              <li><a href="#1">Contact</a></li>
            </ul>
          </div>

          <div class="flyout__panel" id={`${id}-panel-wildlife`}>
            <div class="flyout__panel-title">
              <p>Wildlife</p>
            </div>
            <ul class="nav nav--divider">
              <li>
                <button data-flyout-next aria-controls={`${id}-panel-birds`} type="button">
                  Birds
                  <span class="icon icon-arrow-right" aria-hidden="true"></span>
                </button>
              </li>
              <li>
                <button data-flyout-next aria-controls={`${id}-panel-mammals`} type="button">
                  Mammals
                  <span class="icon icon-arrow-right" aria-hidden="true"></span>
                </button>
              </li>
              <li>
                <button data-flyout-next aria-controls={`${id}-panel-reptiles`} type="button">
                  Reptiles
                  <span class="icon icon-arrow-right" aria-hidden="true"></span>
                </button>
              </li>
              <li><a href="#1">All Wildlife</a></li>
            </ul>
          </div>

          <div class="flyout__panel" id={`${id}-panel-trails`}>
            <div class="flyout__panel-title">
              <p>Trails</p>
            </div>
            <ul class="nav nav--divider">
              <li><a href="#1">Easy</a></li>
              <li><a href="#1">Moderate</a></li>
              <li><a href="#1">Strenuous</a></li>
              <li><a href="#1">All Trails</a></li>
            </ul>
          </div>

          <div class="flyout__panel" id={`${id}-panel-birds`}>
            <div class="flyout__panel-title">
              <p>Birds</p>
            </div>
            <ul class="nav nav--divider">
              <li><a href="#1">Waterfowl</a></li>
              <li><a href="#1">Raptors</a></li>
              <li><a href="#1">Shorebirds</a></li>
              <li><a href="#1">All Birds</a></li>
            </ul>
          </div>

          <div class="flyout__panel" id={`${id}-panel-mammals`}>
            <div class="flyout__panel-title">
              <p>Mammals</p>
            </div>
            <ul class="nav nav--divider">
              <li><a href="#1">Bears</a></li>
              <li><a href="#1">Deer</a></li>
              <li><a href="#1">Foxes</a></li>
              <li><a href="#1">All Mammals</a></li>
            </ul>
          </div>

          <div class="flyout__panel" id={`${id}-panel-reptiles`}>
            <div class="flyout__panel-title">
              <p>Reptiles</p>
            </div>
            <ul class="nav nav--divider">
              <li><a href="#1">Turtles</a></li>
              <li><a href="#1">Lizards</a></li>
              <li><a href="#1">Snakes</a></li>
              <li><a href="#1">All Reptiles</a></li>
            </ul>
          </div>
        </div>
      </nav>
    </div>
  </div>
</div>
