<script>
  import Lightbox from '../../../../../../packages/core/src/js/lightbox';

  const setupKey = '__natura11yDocsLightbox';

  const setupLightbox = () => {
    if (Reflect.get(window, setupKey)) {
      return;
    }

    Reflect.set(window, setupKey, true);
    new Lightbox().init();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupLightbox, { once: true });
  } else {
    setupLightbox();
  }
</script>
