---
import { exampleStyle } from '../shared/exampleStyles';
---

<div class="font-size-md text-align-center" style={exampleStyle}>
  <div
    class="theme- border box-shadow-1 z-index-300"
    style="width: 90%; padding: 1.5em 1em 1em 1em; --border-color: currentColor;"
  >
    <p class="margin-bottom-1">Z-index value 300</p>
    <p>
      <code>.z-index-300</code>
    </p>
  </div>

  <div
    class="theme- border box-shadow-1 z-index-200"
    style="width: 90%; padding: 1.5em 1em 1em 1em; margin-inline-start: 5%; margin-block-start: -1em; --border-color: currentColor;"
  >
    <p class="margin-bottom-1">Z-index value 200</p>
    <p>
      <code>.z-index-200</code>
    </p>
  </div>

  <div
    class="theme- border box-shadow-1 z-index-100"
    style="width: 90%; padding: 1.5em 1em 1em 1em; margin-inline-start: 10%; margin-block-start: -1em; --border-color: currentColor;"
  >
    <p class="margin-bottom-1">Z-index value 100</p>
    <p>
      <code>.z-index-100</code>
    </p>
  </div>
</div>
