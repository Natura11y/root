---
interface Props {
  defaultOpen?: string | null;
  headingLevel?: 2 | 3 | 4 | 5 | 6 | null;
  idPrefix?: string;
  textUnderline?: boolean;
}

const {
  defaultOpen = null,
  headingLevel = null,
  idPrefix = '',
  textUnderline = false,
} = Astro.props;

const HeadingTag = headingLevel ? `h${headingLevel}` : null;
const openItemId = defaultOpen ? `${idPrefix}${defaultOpen}` : null;

const items = [
  {
    id: 'danaus-plexippus',
    title: 'Danaus Plexippus',
    content: 'The monarch butterfly or simply monarch is a milkweed butterfly in the family Nymphalidae. Other common names, depending on region, include milkweed, common tiger, wanderer, and black veined brown.',
  },
  {
    id: 'papilio-polyxenes',
    title: 'Papilio Polyxenes',
    content: 'The black swallowtail, American swallowtail, or parsnip swallowtail, is a butterfly found throughout much of North America. It is the state butterfly of Oklahoma and New Jersey.',
  },
  {
    id: 'hyalophora-cecropia',
    title: 'Hyalophora Cecropia',
    content: 'The cecropia moth is North America\'s largest native moth. It is a member of the family Saturniidae, or giant silk moths. Females have been documented with a wingspan of five to seven inches or more.',
  },
  {
    id: 'deilephila-elpenor',
    title: 'Deilephila Elpenor',
    content: 'The elephant hawk moth or large elephant hawk moth, is a moth in the family Sphingidae. Its common name is derived from the caterpillar\'s resemblance to an elephant\'s trunk.',
  },
  {
    id: 'papilio-troilus',
    title: 'Papilio Troilus',
    content: 'The spicebush swallowtail or green-clouded butterfly, is a common black swallowtail butterfly found in North America. It has two subspecies: Papilio troilus troilus and Papilio troilus ilioneus.',
  },
];
---

<div class="accordion">
  {items.map((item) => {
    const itemId = `${idPrefix}${item.id}`;
    const buttonId = `${itemId}-button`;
    const panelId = `${itemId}-panel`;
    const isOpen = openItemId === itemId;

    return (
      <>
        {HeadingTag ? (
          <HeadingTag data-accordion="heading">
            <button
              class="accordion__button h5"
              id={buttonId}
              data-accordion="button"
              aria-controls={panelId}
              aria-expanded={isOpen ? 'true' : 'false'}
            >
              {textUnderline ? <span class="text">{item.title}</span> : item.title}
            </button>
          </HeadingTag>
        ) : (
          <button
            class="accordion__button h5"
            id={buttonId}
            data-accordion="button"
            aria-controls={panelId}
            aria-expanded={isOpen ? 'true' : 'false'}
          >
            {textUnderline ? <span class="text">{item.title}</span> : item.title}
          </button>
        )}

        <div
          class:list={['accordion__panel', { shown: isOpen }]}
          id={panelId}
          data-accordion="panel"
          aria-labelledby={buttonId}
          role="region"
        >
          <div class="accordion__panel__content">
            <p>{item.content}</p>
          </div>
        </div>
      </>
    );
  })}
</div>
