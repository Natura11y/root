---
interface Props {
  defaultOpen?: string | null;
  headingLevel?: 2 | 3 | 4 | 5 | 6 | null;
  idPrefix?: string;
  textUnderline?: boolean;
}

const {
  defaultOpen = null,
  headingLevel = null,
  idPrefix = '',
  textUnderline = false,
} = Astro.props;

const HeadingTag = headingLevel ? `h${headingLevel}` : null;
const openItemId = defaultOpen ? `${idPrefix}${defaultOpen}` : null;

const items = [
  {
    id: 'danaus-plexippus',
    title: 'Danaus Plexippus',
    content: 'The monarch butterfly is one of the most familiar butterflies in North America. Its orange and black pattern makes it instantly recognizable.',
  },
  {
    id: 'papilio-glaucus',
    title: 'Papilio Glaucus',
    content: 'The eastern tiger swallowtail is a large butterfly known for yellow wings, black tiger-like stripes, and graceful flight.',
  },
  {
    id: 'vanessa-cardui',
    title: 'Vanessa Cardui',
    content: 'The painted lady is widely distributed and highly migratory, appearing across many regions and habitats throughout the year.',
  },
];
---

<div class="accordion">
  {items.map((item) => {
    const itemId = `${idPrefix}${item.id}`;
    const buttonId = `${itemId}-button`;
    const panelId = `${itemId}-panel`;
    const isOpen = openItemId === itemId;

    return (
      <>
        {HeadingTag ? (
          <HeadingTag data-accordion="heading">
            <button
              class="accordion__button h5"
              id={buttonId}
              data-accordion="button"
              aria-controls={panelId}
              aria-expanded={isOpen ? 'true' : 'false'}
            >
              {textUnderline ? <span class="text">{item.title}</span> : item.title}
            </button>
          </HeadingTag>
        ) : (
          <button
            class="accordion__button h5"
            id={buttonId}
            data-accordion="button"
            aria-controls={panelId}
            aria-expanded={isOpen ? 'true' : 'false'}
          >
            {textUnderline ? <span class="text">{item.title}</span> : item.title}
          </button>
        )}

        <div
          class:list={['accordion__panel', { shown: isOpen }]}
          id={panelId}
          data-accordion="panel"
          aria-labelledby={buttonId}
          role="region"
        >
          <div class="accordion__panel__content">
            <p>{item.content}</p>
          </div>
        </div>
      </>
    );
  })}
</div>
