<script>
  import Dropdown from '../../../../../../packages/core/src/js/dropdown';

  const setupKey = '__natura11yDocsDropdown';

  const setupDropdown = () => {
    if (Reflect.get(window, setupKey)) return;
    Reflect.set(window, setupKey, true);
    new Dropdown().init();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupDropdown, { once: true });
  } else {
    setupDropdown();
  }
</script>
