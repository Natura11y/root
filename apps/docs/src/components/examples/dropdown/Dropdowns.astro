---
import { exampleStyle } from '../shared/exampleStyles';

interface Props {
  utilities?: string | null;
}

const { utilities = null } = Astro.props;
const clickMenuId = utilities ? 'click-menu-horizontal' : 'click-menu-vertical';
const hoverMenuId = utilities ? 'hover-menu-horizontal' : 'hover-menu-vertical';
---

<div class="display-flex aspect-ratio-3x2 border" style={exampleStyle}>
  <nav class="width-100 padding-4 align-self-start">
    <ul class:list={['nav nav--divider border', utilities]}>
      <li>
        <button
          class="dropdown"
          data-toggle="dropdown"
          aria-controls={clickMenuId}
          aria-expanded="false"
          type="button"
        >
          <span class="text">Click Dropdown</span>
        </button>

        <ul class="dropdown__menu" id={clickMenuId}>
          <li><a href="#1">Link 1</a></li>
          <li><a href="#1">Link 2</a></li>
          <li><a href="#1">Link 3</a></li>
        </ul>
      </li>

      <li>
        <button
          class="dropdown"
          data-toggle="dropdown"
          data-hover="true"
          aria-controls={hoverMenuId}
          aria-expanded="false"
          type="button"
        >
          <span class="text">Hover Dropdown</span>
        </button>

        <ul class="dropdown__menu" id={hoverMenuId}>
          <li><a href="#1">Link 1</a></li>
          <li><a href="#1">Link 2</a></li>
          <li><a href="#1">Link 3</a></li>
        </ul>
      </li>
    </ul>
  </nav>
</div>
