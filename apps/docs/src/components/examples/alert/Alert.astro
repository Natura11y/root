---
interface Props {
  dismissable?: boolean;
  hasDescription?: boolean;
  idPrefix?: string;
  inverse?: boolean;
  styleVariation?: boolean;
}

const {
  dismissable = false,
  hasDescription = true,
  idPrefix = 'alert-example',
  inverse = false,
  styleVariation = false,
} = Astro.props;

const confirmClass = inverse ? 'alert--confirm--inverse' : 'alert--confirm';
const warnClass = inverse ? 'alert--warn--inverse' : 'alert--warn';

const getAlertAttributes = (id: string, hasDesc: boolean) => ({
  'aria-atomic': dismissable ? 'true' : undefined,
  'aria-describedby': hasDesc ? `${id}-description` : undefined,
  'aria-labelledby': `${id}-label`,
  'aria-live': dismissable ? 'assertive' : undefined,
  role: 'alert',
} as const);
---

{styleVariation ? (
  <div
    class="alert theme-secondary text-align-center border-radius-2"
    {...getAlertAttributes(`${idPrefix}-mail`, true)}
  >
    <div class="alert__title h5">
      <span class="icon icon-mail" aria-hidden="true"></span>
      <span class="alert__title__text" id={`${idPrefix}-mail-label`}>
        You have new mail
      </span>
    </div>

    <div class="alert__description" id={`${idPrefix}-mail-description`}>
      <p>
        You have <strong>(4)</strong> unread messages waiting in <a href="#1">your account dashboard</a>.
      </p>
    </div>
  </div>
) : (
  <div class="grid gap-3">
    <div
      class:list={['alert', confirmClass]}
      {...getAlertAttributes(`${idPrefix}-confirm`, hasDescription)}
    >
      {dismissable && (
        <button
          class="button button--icon-only"
          aria-label="Close alert"
          data-alert-close
          type="button"
        >
          <span class="icon icon-close" aria-hidden="true"></span>
        </button>
      )}

      <div class="alert__title h5">
        <span class="icon icon-confirm" aria-hidden="true"></span>
        <span class="alert__title__text" id={`${idPrefix}-confirm-label`}>
          Alert Confirm
        </span>
      </div>

      {hasDescription && (
        <div class="alert__description" id={`${idPrefix}-confirm-description`}>
          <p>
            Thank you for your feedback. A confirmation message has been sent to your email. Return to our <a href="#1">homepage</a>.
          </p>
        </div>
      )}
    </div>

    <div
      class:list={['alert', warnClass]}
      {...getAlertAttributes(`${idPrefix}-warn`, hasDescription)}
    >
      {dismissable && (
        <button
          class="button button--icon-only"
          aria-label="Close alert"
          data-alert-close
          type="button"
        >
          <span class="icon icon-close" aria-hidden="true"></span>
        </button>
      )}

      <div class="alert__title h5">
        <span class="icon icon-warn" aria-hidden="true"></span>
        <span class="alert__title__text" id={`${idPrefix}-warn-label`}>
          Alert Warn
        </span>
      </div>

      {hasDescription && (
        <div class="alert__description" id={`${idPrefix}-warn-description`}>
          <p>
            Your feedback was not sent. Complete <a href="#1">all required fields</a> below and submit the form again.
          </p>
        </div>
      )}
    </div>
  </div>
)}

{dismissable && (
  <script>
    import Alert from '../../../../../../packages/core/src/js/alert';

    const setupKey = '__natura11yDocsAlert';

    if (!Reflect.get(window, setupKey)) {
      Reflect.set(window, setupKey, true);
      new Alert().init();
    }
  </script>
)}
