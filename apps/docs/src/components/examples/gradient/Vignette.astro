---
import { Image } from 'astro:assets';
import { exampleStyle } from '../shared/exampleStyles';
import gradientImage from './images/gradient-mask-vignette.jpg';
---

<div style={exampleStyle}>
  <Image
    class="gradient-mask-vignette border-radius-2"
    src={gradientImage}
    alt="Snow-covered mountain peak with rugged rock faces, softly illuminated by warm light against a dark blue sky"
    layout="full-width"
  />
</div>
