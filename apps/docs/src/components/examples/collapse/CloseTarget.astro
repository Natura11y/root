---
import { exampleStyle } from '../shared/exampleStyles';
---

<div style={exampleStyle}>
  <div class="grid grid--column-2 gap-3">
    <button
      class="button width-100 theme-primary"
      data-toggle="collapse"
      aria-controls="collapse-target-one-example"
      aria-expanded="false"
      data-target-close="collapse-target-two-example"
      type="button"
    >
      Button 1
    </button>

    <button
      class="button width-100 theme-primary"
      data-toggle="collapse"
      aria-controls="collapse-target-two-example"
      aria-expanded="false"
      data-target-close="collapse-target-one-example"
      type="button"
    >
      Button 2
    </button>
  </div>

  <div class="collapse margin-y-3" id="collapse-target-one-example">
    <div class="border padding-4">
      <p>Target 1</p>
    </div>
  </div>

  <div class="collapse margin-y-3" id="collapse-target-two-example">
    <div class="border padding-4">
      <p>Target 2</p>
    </div>
  </div>
</div>
