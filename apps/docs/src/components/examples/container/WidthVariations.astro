---
import { exampleStyle } from '../shared/exampleStyles';
import Item from './Item.astro';
---

<figure class="margin-y-5">
  <div class="container grid gap-3" style={exampleStyle}>
    <li>
      <Item label="(narrow width)" widthClass="narrow" />
    </li>
    <li>
      <Item label="(medium width)" widthClass="medium" />
    </li>
    <li>
      <Item label="(wide width)" widthClass="wide" />
    </li>
  </div>
</figure>
