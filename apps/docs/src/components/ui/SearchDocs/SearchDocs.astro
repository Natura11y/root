---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { DocSection } from '../../../utilities/docSections';
import './search-docs.css';

interface SearchPage {
  doc: CollectionEntry<'docs'>;
  sections: DocSection[];
}

interface Props {
  pages?: SearchPage[];
}

const { pages = [] } = Astro.props;

const visiblePages = pages
  .filter(({ doc }) => doc.data.draft !== true)
  .sort((a, b) => a.doc.data.title.localeCompare(b.doc.data.title));

const modalId = 'docs-search-modal';
const inputId = 'docs-search-input';
const resultsId = 'docs-search-results';

const getKeywords = ({ doc, sections }: SearchPage) => [
  doc.data.title,
  doc.data.description ?? '',
  ...sections.map((section) => section.text),
].join(' ').toLowerCase();

const getVisibleSections = (sections: DocSection[]) => (
  sections.filter((section) => section.id !== 'introduction')
);
---

<div
  class="modal padding-2"
  id={modalId}
  aria-hidden="true"
  data-modal-close-outside="true"
>
  <div
    class="modal__content wide border-radius-2 box-shadow-3 align-content-stretch"
    aria-labelledby={`${modalId}-title`}
    aria-describedby={`${modalId}-description`}
    role="dialog"
    aria-modal="true"
  >
    <header class="modal__content__head border-bottom">
      <div>
        <h2 class="h5" id={`${modalId}-title`}>
          Search Docs
        </h2>
        <p class="screen-reader-only" id={`${modalId}-description`}>
          Search documentation pages and page sections.
        </p>
      </div>

      <button class="button button--icon-only" type="button" data-modal-close>
        <span class="icon icon-close" aria-hidden="true"></span>
        <span class="screen-reader-only">Close search</span>
      </button>
    </header>

    <main class="modal__content__body docs-search" data-doc-search-root>
      <form class="form-entry form-entry--search" role="search" aria-label="Search docs" data-doc-search-form>
        <label class="form-entry__field">
          <span class="form-entry__field__label screen-reader-only">Search Docs</span>
          <span class="form-entry__field__input">
            <span class="icon icon-search opacity-50" aria-hidden="true"></span>
            <input
              type="search"
              id={inputId}
              name="docs-search"
              placeholder="Filter pages and sections"
              aria-controls={resultsId}
              autocomplete="off"
              data-doc-search
            />
            <button
              class="button button--icon-only"
              type="button"
              data-search-clear
              aria-label="Clear search"
              aria-controls={inputId}
            >
              <span class="icon icon-clear" aria-hidden="true"></span>
            </button>
          </span>
        </label>
      </form>

      <p class="screen-reader-only" aria-live="polite" data-doc-search-status>
        {visiblePages.length} pages available.
      </p>

      <ul class="grid grid--column-3--lg gap-2 margin-y-3" id={resultsId}>
        {visiblePages.map((page) => {
          const { doc, sections } = page;
          const visibleSections = getVisibleSections(sections);

          return (
            <li data-doc-search-item data-doc-search-keywords={getKeywords(page)}>
              <article class="card subtle-fill-1 border-radius-2">
                <a
                  class="card__media docs-search__media backdrop theme-dark"
                  href={`/docs/${doc.data.slug}/`}
                  data-doc-search-close
                >
                  {doc.data.bannerImage && (
                    <div class="backdrop__media">
                      <Picture
                        class="opacity-40"
                        src={doc.data.bannerImage}
                        formats={['avif', 'webp']}
                        alt=""
                        loading="lazy"
                      />
                    </div>
                  )}

                  <div class="backdrop__cover">
                    <div class="container width-100">
                      <h3
                        class="h4 font-weight-normal text-shadow"
                        data-doc-search-label
                      >
                        {doc.data.title}
                      </h3>
                    </div>
                  </div>
                </a>

                <div class="card__body padding-0">
                  <nav aria-label={`${doc.data.title} sections`}>
                    <ul class="nav nav--divider font-size-md">
                      <li>
                        <a
                          href={`/docs/${doc.data.slug}/#introduction`}
                          data-doc-search-close
                          data-doc-search-label
                        >
                          Introduction
                        </a>
                      </li>
                      {visibleSections.map((section) => (
                        <li>
                          <a
                            href={`/docs/${doc.data.slug}/#${section.id}`}
                            data-doc-search-close
                            data-doc-search-label
                          >
                            {section.text}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </nav>
                </div>
              </article>
            </li>
          );
        })}
      </ul>

      <div class="container narrow text-align-center margin-y-5" data-doc-search-no-results hidden>
        <pre class="h2 code-font" aria-hidden="true">
          <code data-doc-search-no-results-art></code>
        </pre>
        <p class="h6">
          No results found for '<span data-doc-search-term></span>'
        </p>
      </div>
    </main>
  </div>
</div>

<script>
  const initializeDocsSearch = () => {
    const roots = Array.from(document.querySelectorAll<HTMLElement>('[data-doc-search-root]'));
    const noResultsArtwork = [
      `.__.
{O,o}
/)__)
" "`,
      `/\\_/\\
( o.o )
>^_^<`,
      `><(((º>
'''`,
      ` (\\(\\
  ( -.-)
o_(")(")`,
      `/\\_/\\
(°ᴥ°)
/  \\`,
    ];

    const escapeRegExp = (value: string) => value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

    const highlightText = (element: HTMLElement, query: string) => {
      const originalText = element.dataset.docSearchOriginalText ?? element.textContent ?? '';
      element.dataset.docSearchOriginalText = originalText;
      element.textContent = '';

      if (!query) {
        element.textContent = originalText;
        return;
      }

      const regex = new RegExp(`(${escapeRegExp(query)})`, 'gi');
      const parts = originalText.split(regex);

      parts.forEach((part) => {
        if (!part) {
          return;
        }

        if (part.toLowerCase() === query.toLowerCase()) {
          const marker = document.createElement('mark');
          marker.textContent = part;
          element.appendChild(marker);
          return;
        }

        element.appendChild(document.createTextNode(part));
      });
    };

    roots.forEach((root) => {
      const modal = root.closest<HTMLElement>('.modal');
      const searchForm = root.querySelector<HTMLFormElement>('[data-doc-search-form]');
      const searchInput = root.querySelector<HTMLInputElement>('[data-doc-search]');
      const searchItems = Array.from(root.querySelectorAll<HTMLElement>('[data-doc-search-item]'));
      const labels = Array.from(root.querySelectorAll<HTMLElement>('[data-doc-search-label]'));
      const noResults = root.querySelector<HTMLElement>('[data-doc-search-no-results]');
      const noResultsArt = root.querySelector<HTMLElement>('[data-doc-search-no-results-art]');
      const searchTerm = root.querySelector<HTMLElement>('[data-doc-search-term]');
      const searchStatus = root.querySelector<HTMLElement>('[data-doc-search-status]');
      const closeLinks = Array.from(root.querySelectorAll<HTMLAnchorElement>('[data-doc-search-close]'));
      let lastNoResultsQuery = '';
      let wasOpen = modal?.classList.contains('shown') ?? false;

      if (!searchInput || searchItems.length === 0) {
        return;
      }

      const setNoResultsArtwork = (query: string) => {
        if (!noResultsArt || query === lastNoResultsQuery) {
          return;
        }

        const randomIndex = Math.floor(Math.random() * noResultsArtwork.length);
        noResultsArt.textContent = noResultsArtwork[randomIndex] ?? noResultsArtwork[0];
        lastNoResultsQuery = query;
      };

      const filterDocs = () => {
        const query = searchInput.value.trim().toLowerCase();
        let visibleCount = 0;

        searchItems.forEach((item) => {
          const keywords = item.dataset.docSearchKeywords ?? '';
          const isMatch = query === '' || keywords.includes(query);

          item.hidden = !isMatch;

          if (isMatch) {
            visibleCount += 1;
          }
        });

        labels.forEach((label) => highlightText(label, query));

        if (noResults) {
          noResults.hidden = visibleCount > 0;
        }

        if (visibleCount === 0) {
          setNoResultsArtwork(query);
        } else {
          lastNoResultsQuery = '';
        }

        if (searchTerm) {
          searchTerm.textContent = query;
        }

        if (searchStatus) {
          searchStatus.textContent = query
            ? `${visibleCount} pages found for ${query}.`
            : `${visibleCount} pages available.`;
        }
      };

      const resetSearch = () => {
        searchInput.value = '';
        filterDocs();
      };

      searchForm?.addEventListener('submit', (event) => {
        event.preventDefault();
      });

      searchInput.addEventListener('input', filterDocs);

      modal?.addEventListener('click', (event) => {
        const target = event.target;

        if (!(target instanceof Element)) {
          return;
        }

        if (target.closest('[data-modal-close]')) {
          resetSearch();
        }
      });

      closeLinks.forEach((link) => {
        link.addEventListener('click', resetSearch);
      });

      if (modal) {
        const handleModalState = () => {
          const isOpen = modal.classList.contains('shown');

          if (isOpen && !wasOpen) {
            requestAnimationFrame(() => {
              searchInput.focus();
            });
          }

          if (!isOpen && wasOpen) {
            resetSearch();
          }

          wasOpen = isOpen;
        };

        const observer = new MutationObserver(handleModalState);
        observer.observe(modal, { attributes: true, attributeFilter: ['class'] });
      }

      filterDocs();
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeDocsSearch, { once: true });
  } else {
    initializeDocsSearch();
  }
</script>
