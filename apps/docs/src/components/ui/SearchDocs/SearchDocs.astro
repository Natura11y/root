---
import './search-docs.scss';
import SearchDocsIsland from './SearchDocsIsland';

// These values are intentionally public and are included in the browser bundle.
// Environment variables can still override them when the search configuration changes.
const defaultSearchConfig = {
  appId: '5IEOINWJ42',
  apiKey: '32dca3d2e631700db6477c1f1445c2d5',
  indexName: 'Natura11y Docs',
};

const appId = import.meta.env.PUBLIC_ALGOLIA_APP_ID || defaultSearchConfig.appId;
const apiKey = import.meta.env.PUBLIC_ALGOLIA_SEARCH_API_KEY || defaultSearchConfig.apiKey;
const indexName = import.meta.env.PUBLIC_ALGOLIA_INDEX_NAME || defaultSearchConfig.indexName;
---

<SearchDocsIsland
  client:load
  appId={appId}
  apiKey={apiKey}
  indexName={indexName}
/>
