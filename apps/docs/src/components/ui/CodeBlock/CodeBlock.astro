---
import { Code } from 'astro-expressive-code/components';

type MarkerLineOrRange = number | LineAnnotation;
type InlineMarkerDefinition = string | RegExp;
type MarkerDefinition = InlineMarkerDefinition | MarkerLineOrRange;

interface LineAnnotation {
  range: string;
  label?: string;
}

interface Props {
  codeId?: string | null;
  highlightedLines?: string | null;
  lineAnnotations?: LineAnnotation[];
  showLineNumbers?: boolean | null;
  showCodeFrame?: boolean;
  codeLanguage?: string;
  code?: string | null;
  markedText?: InlineMarkerDefinition | InlineMarkerDefinition[] | null;
}

const {
  codeId = null,
  highlightedLines = null,
  lineAnnotations = [],
  showLineNumbers = null,
  showCodeFrame = true,
  codeLanguage = 'html',
  code = null,
  markedText = null,
} = Astro.props;

const codeText = code;
const language = codeLanguage.toLowerCase();
const annotationLinesValue = lineAnnotations.length
  ? lineAnnotations.map((annotation) => annotation.range).join(',')
  : null;
const highlightedLinesValue = highlightedLines == null ? annotationLinesValue : String(highlightedLines);
const languageLabels: Record<string, string> = {
  bash: 'Shell',
  css: 'CSS',
  html: 'HTML',
  javascript: 'JavaScript',
  js: 'JavaScript',
  json: 'JSON',
  jsx: 'JSX',
  markup: 'HTML',
  scss: 'SCSS',
  shell: 'Shell',
  ts: 'TypeScript',
  tsx: 'TSX',
  typescript: 'TypeScript',
};
const languageLabel = languageLabels[language] ?? language.toUpperCase();

const parseLineMarkers = (value: string | null) => {
  if (!value) {
    return undefined;
  }

  const markers = value
    .split(',')
    .map((part) => {
      const range = part.trim().replace(/\s+/gu, '');

      if (!range) {
        return null;
      }

      if (range.includes('-')) {
        return { range };
      }

      const lineNumber = Number.parseInt(range, 10);
      return Number.isNaN(lineNumber) ? null : lineNumber;
    })
    .filter((marker): marker is MarkerLineOrRange => marker !== null);

  return markers.length ? markers : undefined;
};

const markers = parseLineMarkers(highlightedLinesValue);
const annotationMarkers = lineAnnotations;
const lineHighlightDefinitions = annotationMarkers.length ? annotationMarkers : markers ?? [];
const inlineMarkDefinitions = Array.isArray(markedText)
  ? markedText
  : markedText
    ? [markedText]
    : [];
const markDefinitions: MarkerDefinition[] = [
  ...lineHighlightDefinitions,
  ...inlineMarkDefinitions,
];
const shouldShowLineNumbers = showLineNumbers ?? lineAnnotations.length > 0;
---

<div
  class="example__code example__code--expressive-code"
  data-code-id={codeId ?? undefined}
  data-line-anchors={highlightedLinesValue ?? undefined}
>
  {codeText && showCodeFrame && (
    <div class="example__code__header">
      <span class="example__code__language">{languageLabel}</span>

      <button
        class="button example__code__copy"
        type="button"
        data-code-copy
      >
        Copy
      </button>
    </div>
  )}

  {codeText ? (
    <>
      <Code
        code={codeText}
        lang={language}
        frame="none"
        mark={markDefinitions.length ? markDefinitions : undefined}
        showLineNumbers={shouldShowLineNumbers}
      />

      {showCodeFrame && (
        <template data-code-source>{codeText}</template>
      )}
    </>
  ) : (
    <p>No code provided.</p>
  )}
</div>

<script>
  type CodeLineAnchor = {
    start: number;
    range: string;
  };

  const setupKey = '__natura11yCodeLineAnchors';

  if (!Reflect.get(window, setupKey)) {
    Reflect.set(window, setupKey, true);

    const getAnchorRanges = (value: string): CodeLineAnchor[] => {
      return value
        .split(',')
        .map((part: string) => part.trim().replace(/\s+/gu, ''))
        .filter(Boolean)
        .map((range: string) => {
          const start = Number.parseInt(range.split('-')[0] ?? '', 10);
          return Number.isNaN(start) ? null : { start, range };
        })
        .filter((anchor): anchor is CodeLineAnchor => anchor !== null);
    };

    const applyLineAnchors = (): void => {
      document.querySelectorAll('[data-code-id][data-line-anchors]').forEach((codeBlock) => {
        const codeId = codeBlock.getAttribute('data-code-id');
        const lineAnchors = codeBlock.getAttribute('data-line-anchors');

        if (!codeId || !lineAnchors) {
          return;
        }

        const lines = codeBlock.querySelectorAll('.ec-line');
        const ranges = getAnchorRanges(lineAnchors);

        ranges.forEach(({ start, range }) => {
          const line = lines[start - 1];

          if (line instanceof HTMLElement) {
            line.id = `${codeId}.${range}`;
          }
        });
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', applyLineAnchors, { once: true });
    } else {
      applyLineAnchors();
    }
  }
</script>

<script>
  const copySetupKey = '__natura11yCodeCopy';

  if (!Reflect.get(window, copySetupKey)) {
    Reflect.set(window, copySetupKey, true);

    const copyWithFallback = (value: string): boolean => {
      const field = document.createElement('textarea');
      field.value = value;
      field.setAttribute('readonly', '');
      field.style.position = 'fixed';
      field.style.insetBlockStart = '0';
      field.style.insetInlineStart = '-9999px';

      document.body.append(field);
      field.select();

      let didCopy = false;

      try {
        didCopy = document.execCommand('copy');
      } finally {
        field.remove();
      }

      return didCopy;
    };

    const setCopyButtonText = (button: HTMLButtonElement, value: string): void => {
      button.textContent = value;
      button.setAttribute('aria-label', value === 'Copied' ? 'Code copied' : 'Copy code');
    };

    document.addEventListener('click', async (event) => {
      const target = event.target;

      if (!(target instanceof Element)) {
        return;
      }

      const button = target.closest('[data-code-copy]');

      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      const codeBlock = button.closest('.example__code');
      const source = codeBlock?.querySelector('[data-code-source]');

      if (!(source instanceof HTMLTemplateElement)) {
        return;
      }

      const code = source.content.textContent ?? '';
      let didCopy = false;

      try {
        await navigator.clipboard.writeText(code);
        didCopy = true;
      } catch {
        didCopy = copyWithFallback(code);
      }

      if (!didCopy) {
        return;
      }

      setCopyButtonText(button, 'Copied');
      window.setTimeout(() => setCopyButtonText(button, 'Copy'), 1500);
    });
  }
</script>
