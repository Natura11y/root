---
import { Code } from 'astro-expressive-code/components';

type MarkerLineOrRange = number | LineAnnotation;
type InlineMarkerDefinition = string | RegExp;
type MarkerDefinition = InlineMarkerDefinition | MarkerLineOrRange;

interface LineAnnotation {
  range: string;
  label?: string;
}

interface Props {
  codeId?: string | null;
  highlightedLines?: string | null;
  lineAnnotations?: LineAnnotation[];
  showLineNumbers?: boolean | null;
  showCodeFrame?: boolean;
  codeLanguage?: string;
  code?: string | null;
  markedText?: InlineMarkerDefinition | InlineMarkerDefinition[] | null;
}

const {
  codeId = null,
  highlightedLines = null,
  lineAnnotations = [],
  showLineNumbers = null,
  showCodeFrame = true,
  codeLanguage = 'html',
  code = null,
  markedText = null,
} = Astro.props;

const codeText = code;
const language = codeLanguage.toLowerCase();
const annotationLinesValue = lineAnnotations.length
  ? lineAnnotations.map((annotation) => annotation.range).join(',')
  : null;
const highlightedLinesValue = highlightedLines == null ? annotationLinesValue : String(highlightedLines);
const languageLabels: Record<string, string> = {
  bash: 'Shell',
  css: 'CSS',
  html: 'HTML',
  javascript: 'JavaScript',
  js: 'JavaScript',
  json: 'JSON',
  jsx: 'JSX',
  markup: 'HTML',
  scss: 'SCSS',
  shell: 'Shell',
  ts: 'TypeScript',
  tsx: 'TSX',
  typescript: 'TypeScript',
};
const languageLabel = languageLabels[language] ?? language.toUpperCase();

const parseLineMarkers = (value: string | null) => {
  if (!value) {
    return undefined;
  }

  const markers = value
    .split(',')
    .map((part) => {
      const range = part.trim().replace(/\s+/gu, '');

      if (!range) {
        return null;
      }

      if (range.includes('-')) {
        return { range };
      }

      const lineNumber = Number.parseInt(range, 10);
      return Number.isNaN(lineNumber) ? null : lineNumber;
    })
    .filter((marker): marker is MarkerLineOrRange => marker !== null);

  return markers.length ? markers : undefined;
};

const markers = parseLineMarkers(highlightedLinesValue);
const annotationMarkers = lineAnnotations;
const lineHighlightDefinitions = annotationMarkers.length ? annotationMarkers : markers ?? [];
const inlineMarkDefinitions = Array.isArray(markedText)
  ? markedText
  : markedText
    ? [markedText]
    : [];
const markDefinitions: MarkerDefinition[] = [
  ...lineHighlightDefinitions,
  ...inlineMarkDefinitions,
];
const shouldShowLineNumbers = showLineNumbers ?? lineAnnotations.length > 0;
---

<div
  class="example__code example__code--expressive-code"
  data-code-id={codeId ?? undefined}
  data-line-anchors={highlightedLinesValue ?? undefined}
>
  {codeText && showCodeFrame && (
    <div class="example__code__header">
      <span class="example__code__language">{languageLabel}</span>

      <button
        class="button theme-primary example__code__copy"
        type="button"
        data-code-copy
      >
        Copy
      </button>
    </div>
  )}

  {codeText ? (
    <>
      <Code
        code={codeText}
        lang={language}
        frame="none"
        mark={markDefinitions.length ? markDefinitions : undefined}
        showLineNumbers={shouldShowLineNumbers}
      />

      {showCodeFrame && (
        <template data-code-source>{codeText}</template>
      )}
    </>
  ) : (
    <p>No code provided.</p>
  )}
</div>

<script>
  import './code-block.client';
</script>
