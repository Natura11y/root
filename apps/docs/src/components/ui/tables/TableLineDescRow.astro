---
interface Props {
  lines?: string;
  targetFigure?: string | number;
}

const { lines, targetFigure } = Astro.props;
const lineAnchor = lines && targetFigure ? `#code_${targetFigure}.${lines}` : null;
const lineLabel = lines?.includes('-') ? `code lines ${lines}` : `code line ${lines}`;
---

<tr>
  <td>
    {lineAnchor ? (
      <a
        href={lineAnchor}
        data-line-anchor
        title={`Jump to ${lineLabel}`}
        aria-label={`Jump to ${lineLabel}`}
      >
        {lines}
      </a>
    ) : (
      lines
    )}
  </td>
  <td>
    <slot />
  </td>
</tr>
