---
interface Props {
  lines?: string;
  targetFigure?: string | number;
}

const { lines, targetFigure } = Astro.props;
const lineAnchor = lines && targetFigure ? `#code_${targetFigure}.${lines}` : null;
---

<tr>
  <td>
    {lineAnchor ? (
      <a
        href={lineAnchor}
        data-line-anchor
        title="Jump to code line"
        aria-label={`Jump to code line ${lines}`}
      >
        {lines}
      </a>
    ) : (
      lines
    )}
  </td>
  <td>
    <slot />
  </td>
</tr>
