---
import corePackage from '../../../../../../packages/core/package.json';
import Logo from './Logo.astro';

const version = corePackage.version;
const versionShort = version.split('-')[0];
const pathname = Astro.url.pathname;

const navItems = [
  { href: '/docs/get-started/', label: 'Docs', matchPrefix: '/docs/' },
  { href: '/icons/', label: 'Icons', matchPrefix: '/icons/' },
  { href: '/templates/', label: 'Templates', matchPrefix: '/templates/' },
  { href: '/examples/', label: 'Examples', matchPrefix: '/examples/' },
];

const isCurrent = (item: (typeof navItems)[number]) => pathname.startsWith(item.matchPrefix);
const isCurrentPage = (item: (typeof navItems)[number]) => pathname === item.href;
---

<header class="main-menu--bar--lg box-shadow-1">

  <div class="main-menu__logo">
    <a href="/" title="Home" data-logo="brand">
      <Logo />
    </a>
  </div>

  <nav class="main-menu__nav" id="global-main-menu" aria-label="Main Menu">
    <ul>
      <li>
        <button
          class="dropdown"
          data-toggle="dropdown"
          aria-controls="global-version-menu"
          aria-expanded="false"
          data-hover="true"
          type="button"
        >
          <span class="text">{versionShort}</span>
        </button>
        <ul class="dropdown__menu box-shadow-1--lg" id="global-version-menu">
          <li>
            <a href="/">
              <span class="icon icon-confirm" aria-hidden="true"></span>
              <span class="nav__text">Current: {version}</span>
            </a>
          </li>
          <li>
            <a href="https://gonatura11y.com/v4/" target="_blank" rel="noopener noreferrer">
              <span class="icon icon-open-new" aria-hidden="true"></span>
              <span class="nav__text">v4.x docs</span>
            </a>
          </li>
          <li>
            <a href="https://gonatura11y.com/v3/" target="_blank" rel="noopener noreferrer">
              <span class="icon icon-open-new" aria-hidden="true"></span>
              <span class="nav__text">v3.x docs</span>
            </a>
          </li>
          <li>
            <a href="https://gonatura11y.com/v2/" target="_blank" rel="noopener noreferrer">
              <span class="icon icon-open-new" aria-hidden="true"></span>
              <span class="nav__text">v2.x docs</span>
            </a>
          </li>
          <li>
            <a href="https://gonatura11y.com/v1/" target="_blank" rel="noopener noreferrer">
              <span class="icon icon-open-new" aria-hidden="true"></span>
              <span class="nav__text">v1.x docs</span>
            </a>
          </li>
        </ul>
      </li>
      {navItems.map((item) => (
        <li>
          <a
            class:list={[isCurrent(item) && 'font-weight-bold']}
            href={item.href}
            aria-current={isCurrentPage(item) ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="main-menu__toggle">
    <button
      class="button button--icon-only"
      aria-label="Menu"
      data-toggle="collapse"
      aria-controls="global-main-menu"
      aria-expanded="false"
      type="button"
    >
      <span class="icon icon-menu" aria-hidden="true"></span>
    </button>
  </div>

  <div class="main-menu__actions theme-picker">
    <button
      class="button button--icon-only"
      aria-label="Theme"
      title="Theme"
      data-toggle="dropdown"
      aria-controls="global-theme-menu"
      aria-expanded="false"
      type="button"
    >
      <span class="icon icon-mode-light-dark" aria-hidden="true"></span>
    </button>
    <ul class="dropdown__menu theme-picker__dropdown nav nav--divider box-shadow-1" id="global-theme-menu" role="menu">
      <li>
        <button type="button" data-theme-option="light" role="menuitemradio" aria-checked="false">
          <span class="icon icon-sun" aria-hidden="true"></span>
          <span class="nav__text">Canvas (default)</span>
        </button>
      </li>
      <li>
        <button type="button" data-theme-option="dark" role="menuitemradio" aria-checked="false">
          <span class="icon icon-moon" aria-hidden="true"></span>
          <span class="nav__text">Dark Mode</span>
        </button>
      </li>
      <li>
        <button type="button" data-theme-option="os" role="menuitemradio" aria-checked="false">
          <span class="icon icon-mode-light-dark" aria-hidden="true"></span>
          <span class="nav__text">Prefers</span>
        </button>
      </li>
    </ul>
  </div>
</header>

<script>
  import Collapse from '../../../../../../packages/core/src/js/collapse';
  import Dropdown from '../../../../../../packages/core/src/js/dropdown';
  import MainMenu from '../../../../../../packages/core/src/js/main-menu';

  const initializeGlobalHeader = () => {
    new Collapse().init();
    new Dropdown().init();
    new MainMenu().init();
  };

  type ThemeOption = 'light' | 'dark' | 'os';

  const storageKey = 'preferred-theme';
  const themeClasses = ['theme-canvas', 'theme-dark', 'theme-canvas--prefers'];
  const themeClassMap: Record<ThemeOption, string> = {
    light: 'theme-canvas',
    dark: 'theme-dark',
    os: 'theme-canvas--prefers',
  };

  const isThemeOption = (value: string | null): value is ThemeOption => (
    value === 'light' || value === 'dark' || value === 'os'
  );

  const getStoredTheme = (): ThemeOption => {
    try {
      const storedTheme = window.localStorage.getItem(storageKey);
      return isThemeOption(storedTheme) ? storedTheme : 'light';
    } catch {
      return 'light';
    }
  };

  const applyTheme = (theme: ThemeOption) => {
    const root = document.documentElement;

    root.classList.remove(...themeClasses);
    root.classList.add(themeClassMap[theme]);
    root.dataset.theme = theme;
  };

  const updateThemePicker = (theme: ThemeOption) => {
    document.querySelectorAll<HTMLButtonElement>('[data-theme-option]').forEach((button) => {
      button.setAttribute('aria-checked', String(button.dataset.themeOption === theme));
    });
  };

  const closeThemePicker = () => {
    const themeMenu = document.getElementById('global-theme-menu');
    const themeButton = document.querySelector<HTMLButtonElement>('[aria-controls="global-theme-menu"]');

    themeMenu?.classList.remove('shown');
    themeButton?.setAttribute('aria-expanded', 'false');
  };

  const initializeThemePicker = () => {
    const currentTheme = isThemeOption(document.documentElement.dataset.theme)
      ? document.documentElement.dataset.theme
      : getStoredTheme();

    updateThemePicker(currentTheme);

    document.addEventListener('click', (event) => {
      const target = event.target;

      if (!(target instanceof Element)) {
        return;
      }

      const themeButton = target.closest<HTMLButtonElement>('[data-theme-option]');
      const selectedTheme = themeButton?.dataset.themeOption ?? null;

      if (!themeButton || !isThemeOption(selectedTheme)) {
        return;
      }

      try {
        window.localStorage.setItem(storageKey, selectedTheme);
      } catch {
        // Ignore storage failures and still update the current page.
      }

      applyTheme(selectedTheme);
      updateThemePicker(selectedTheme);
      closeThemePicker();
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initializeGlobalHeader();
      initializeThemePicker();
    }, { once: true });
  } else {
    initializeGlobalHeader();
    initializeThemePicker();
  }
</script>
