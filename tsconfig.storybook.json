{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@core-js/*": ["./packages/core/src/js/*"],
      "@lib/*": ["./packages/react/src/*"]
    }
  },
  "include": [
    "apps/storybook/.storybook/**/*",
    "apps/storybook/stories/**/*",
    "packages/react/src/types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "storybook-static", "apps/storybook/storybook-static"]
}
