{
  "name": "natura11y-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:react": "npm --workspace @natura11y/react run build",
    "build:icons": "npm --workspace @natura11y/icons run build:icons",
    "typecheck:react": "npm --workspace @natura11y/react run typecheck",
    "storybook": "npm --workspace @natura11y/storybook run storybook",
    "build-storybook": "npm --workspace @natura11y/storybook run build-storybook",
    "build:core": "npm --workspace @natura11y/core run build",
    "start:core": "npm --workspace @natura11y/core run start"
  }
}
