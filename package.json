{
  "name": "natura11y-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:react": "npm --workspace @natura11y/react run build",
    "build:icons": "npm --workspace @natura11y/icons run build:icons",
    "typecheck:react": "npm --workspace @natura11y/react run typecheck",
    "typecheck:storybook": "tsc -p tsconfig.storybook.json --noEmit",
    "storybook": "storybook dev -p 6006 -c apps/storybook/.storybook",
    "build-storybook": "storybook build -c apps/storybook/.storybook",
    "build:core": "npm --workspace @natura11y/core run build",
    "start:core": "npm --workspace @natura11y/core run start",
    "docs:astro": "astro dev --root apps/docs-astro --port 4321",
    "build:docs-astro": "astro build --root apps/docs-astro"
  },
  "devDependencies": {
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/react": "^6.0.1",
    "@chromatic-com/storybook": "^5.0.2",
    "@natura11y/core": "^5.1.1",
    "@natura11y/icons": "^2.1.0",
    "@natura11y/react": "^1.0.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "astro": "^7.0.6",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^10.4.6",
    "typescript": "^5.6.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.0"
  }
}
